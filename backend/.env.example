PORT=5000
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/orderxa?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
CLIENT_URL=http://localhost:5173
SESSION_SECRET=your_session_secret_here
NODE_ENV=development

# SMTP Config for Nodemailer (Email OTP) — use Ethereal for testing, Gmail for production
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Fast2SMS Config (SMS OTP) — sign up at fast2sms.com and paste your API key
FAST2SMS_API_KEY=

# Google Maps API Key (for frontend live tracking maps)
# Create at https://console.cloud.google.com/apis — enable "Maps JavaScript API"
# Add to frontend .env as: VITE_GOOGLE_MAPS_API_KEY=your_key_here
